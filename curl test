    for k := range clients {
        clientKeys = append(clientKeys, k)
    }
    sort.Strings(clientKeys)

    type clientResult struct {
        client    string
        embeddings string
        err       error
    }

    resultsCh := make(chan clientResult, len(clientKeys))
    var wg sync.WaitGroup

    for _, auth := range clientKeys {
        url := clients[auth]
        target := strings.ToLower(auth)
        endpoint := fmt.Sprintf("http://%s:8080/agent/v1/vflTrainRequest/%s", url, target)

        req := make(map[string]any, len(dataRequest)+1)
        for k, v := range dataRequest {
            req[k] = v
        }
        req["type"] = "vflTrainRequest"

        payload, err := json.Marshal(req)
        if err != nil {
            return 0., err
        }

        wg.Add(1)
        go func(clientAuth, ep string, body []byte) {
            defer wg.Done()

            respBody, err := sendData(ep, body)
            if err != nil {
                resultsCh <- clientResult{client: clientAuth, err: err}
                return
            }

            responseJson := &pb.MicroserviceCommunication{}
            if err := json.Unmarshal([]byte(respBody), responseJson); err != nil {
                resultsCh <- clientResult{client: clientAuth, err: err}
                return
            }

            dataMap := responseJson.Data.AsMap()
            emb, ok := dataMap["embeddings"].(string)
            if !ok || emb == "" {
                resultsCh <- clientResult{
                    client: clientAuth,
                    err:    fmt.Errorf("no embeddings returned by %s", clientAuth),
                }
                return
            }

            resultsCh <- clientResult{client: clientAuth, embeddings: emb, err: nil}
        }(auth, endpoint, payload)
    }

    wg.Wait()
    close(resultsCh)
    embeddingsByClient := make(map[string]string, len(clientKeys))
    var errs []string
    for r := range resultsCh {
        if r.err != nil {
            errs = append(errs, fmt.Sprintf("%s: %v", r.client, r.err))
            continue
        }
        embeddingsByClient[r.client] = r.embeddings
    }

    if len(embeddingsByClient) != len(clientKeys) {
        return 0., fmt.Errorf("missing client embeddings (%d/%d). Errors: %s",
            len(embeddingsByClient), len(clientKeys), strings.Join(errs, "; "),
        )
    }

    embeddingList := make([]string, 0, len(clientKeys))
    for _, auth := range clientKeys {
        embeddingList = append(embeddingList, embeddingsByClient[auth])
    }

    serverTarget := strings.ToLower(serverAuth)
    serverEndpoint := fmt.Sprintf("http://%s:8080/agent/v1/vflTrainRequest/%s", serverUrl, serverTarget)

    serverReq := make(map[string]any, len(dataRequest)+2)
    for k, v := range dataRequest {
        serverReq[k] = v
    }
    serverReq["type"] = "vflAggregateRequest"
    serverReq["data"] = map[string]any{
        "embeddings":        embeddingList,
        "trainingBacktrack": trainingBacktrack,
    }

    serverPayload, err := json.Marshal(serverReq)
    if err != nil {
        return 0., err
    }

    serverRespBody, err := sendData(serverEndpoint, serverPayload)
    if err != nil {
        return 0., err
    }

    serverResponse := &pb.MicroserviceCommunication{}
    if err := json.Unmarshal([]byte(serverRespBody), serverResponse); err != nil {
        return 0., err
    }

    accuracy := serverResponse.Data.GetFields()["accuracy"].GetNumberValue()
    gradientList := serverResponse.Data.GetFields()["gradients"].GetListValue().GetValues()

    if len(gradientList) != len(clientKeys) {
        return 0., fmt.Errorf("server returned %d gradients but expected %d", len(gradientList), len(clientKeys))
    }

    gradients := make([]string, 0, len(gradientList))
    for _, val := range gradientList {
        gradients = append(gradients, val.GetStringValue())
    }

    wg = sync.WaitGroup{}
    errCh := make(chan error, len(clientKeys))

    for i, auth := range clientKeys {
        url := clients[auth]
        target := strings.ToLower(auth)
        endpoint := fmt.Sprintf("http://%s:8080/agent/v1/vflTrainRequest/%s", url, target)

        clientReq := make(map[string]any, len(dataRequest)+2)
        for k, v := range dataRequest {
            clientReq[k] = v
        }
        clientReq["type"] = "vflGradientDescentRequest"
        clientReq["data"] = map[string]any{
            "gradients":     gradients[i],
            "learning_rate": learning_rate,
        }

        payload, err := json.Marshal(clientReq)
        if err != nil {
            return 0., err
        }

        wg.Add(1)
        go func(ep string, body []byte) {
            defer wg.Done()
            _, err := sendData(ep, body)
            if err != nil {
                errCh <- err
            }
        }(endpoint, payload)
    }

    wg.Wait()
    close(errCh)
    if len(errCh) > 0 {
        first := <-errCh
        return accuracy, fmt.Errorf("failed sending gradients: %v", first)
    }

    return accuracy, nil
}